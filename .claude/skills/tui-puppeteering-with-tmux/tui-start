#!/usr/bin/env bash
# tui-start: Create isolated tmux session and run command
#
# Usage: tui-start <session-name> <command>

set -euo pipefail

SOCKET="nori-agent-sock"

if [[ $# -lt 2 ]]; then
    echo "Usage: tui-start <session-name> <command>" >&2
    exit 1
fi

SESSION=$1
CMD=$2

# Clean up existing session on isolated socket
tmux -f /dev/null -L "$SOCKET" kill-session -t "$SESSION" 2>/dev/null || true

# Start detached session with enforced geometry
tmux -f /dev/null -L "$SOCKET" new-session -d -s "$SESSION" -x 120 -y 40 "$CMD"

# Disable status bar for clean captures
tmux -f /dev/null -L "$SOCKET" set-option -t "$SESSION" status off

echo "Started session '$SESSION' on socket '$SOCKET'"
