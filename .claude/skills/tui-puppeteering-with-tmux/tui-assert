#!/usr/bin/env bash
# tui-assert: Wait for expected text in tmux session
#
# Usage: tui-assert <session> [-E] <pattern> [timeout-seconds]
#
# Options:
#   -E    Use extended regex instead of fixed string match
#
# Exit codes: 0 = found, 1 = timeout
# On failure: writes <session>_failure.log

set -euo pipefail

SOCKET="nori-agent-sock"
USE_REGEX=false

if [[ $# -lt 2 ]]; then
    echo "Usage: tui-assert <session> [-E] <pattern> [timeout]" >&2
    exit 1
fi

SESSION=$1
shift

if [[ "${1:-}" == "-E" ]]; then
    USE_REGEX=true
    shift
fi

if [[ $# -lt 1 ]]; then
    echo "Usage: tui-assert <session> [-E] <pattern> [timeout]" >&2
    exit 1
fi

PATTERN=$1
TIMEOUT=${2:-5}

END=$((SECONDS + TIMEOUT))

while [[ "$SECONDS" -lt "$END" ]]; do
    CONTENT=$(tmux -f /dev/null -L "$SOCKET" capture-pane -p -t "$SESSION" 2>/dev/null) || true
    if [[ "$USE_REGEX" == true ]]; then
        if echo "$CONTENT" | grep -Eq "$PATTERN"; then
            echo "OK: Found pattern '$PATTERN'"
            exit 0
        fi
    else
        if echo "$CONTENT" | grep -Fq "$PATTERN"; then
            echo "OK: Found '$PATTERN'"
            exit 0
        fi
    fi
    sleep 0.3
done

echo "FAIL: Timed out waiting for '$PATTERN'" >&2
tmux -f /dev/null -L "$SOCKET" capture-pane -p -t "$SESSION" > "${SESSION}_failure.log" 2>/dev/null || true
echo "Screen dumped to ${SESSION}_failure.log" >&2
exit 1
