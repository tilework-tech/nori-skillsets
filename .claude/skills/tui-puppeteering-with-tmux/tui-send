#!/usr/bin/env bash
# tui-send: Send keystrokes to tmux session
#
# Usage:
#   tui-send <session> <text>           # Literal text (no Enter)
#   tui-send <session> --keys <key>     # Special key (Enter, C-c, etc.)

set -euo pipefail

SOCKET="nori-agent-sock"

if [[ $# -lt 2 ]]; then
    echo "Usage: tui-send <session> [--keys] <text>" >&2
    exit 1
fi

SESSION=$1
shift

KEYS_MODE=false
TEXT=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --keys)
            KEYS_MODE=true
            shift
            ;;
        *)
            TEXT="$1"
            shift
            ;;
    esac
done

if [[ -z "$TEXT" ]]; then
    echo "Error: No text/keys provided" >&2
    exit 1
fi

if [[ "$KEYS_MODE" == true ]]; then
    tmux -f /dev/null -L "$SOCKET" send-keys -t "$SESSION" "$TEXT"
else
    tmux -f /dev/null -L "$SOCKET" send-keys -t "$SESSION" -l "$TEXT"
fi
