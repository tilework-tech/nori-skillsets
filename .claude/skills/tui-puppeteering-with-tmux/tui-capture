#!/usr/bin/env bash
# tui-capture: Capture current screen content from tmux session
#
# Usage: tui-capture <session> [-e] [-a] [-S lines]
#
# Options:
#   -e        Include ANSI escape codes (for color verification)
#   -a        Capture alternate/inactive buffer (rarely needed)
#   -S LINES  Include scrollback history (e.g., -S 50 for 50 lines back)

set -euo pipefail

SOCKET="nori-agent-sock"
ANSI_FLAG=""
ALT_FLAG=""
SCROLL_FLAG=""

if [[ $# -lt 1 ]]; then
    echo "Usage: tui-capture <session> [-e] [-a] [-S lines]" >&2
    exit 1
fi

SESSION=$1
shift

while [[ $# -gt 0 ]]; do
    case "$1" in
        -e)
            ANSI_FLAG="-e"
            shift
            ;;
        -a)
            ALT_FLAG="-a"
            shift
            ;;
        -S)
            shift
            if [[ $# -lt 1 ]]; then
                echo "Error: -S requires a number" >&2
                exit 1
            fi
            SCROLL_FLAG="-S -$1"
            shift
            ;;
        *)
            echo "Unknown option: $1" >&2
            exit 1
            ;;
    esac
done

# shellcheck disable=SC2086
tmux -f /dev/null -L "$SOCKET" capture-pane -p -t "$SESSION" $ANSI_FLAG $ALT_FLAG $SCROLL_FLAG
