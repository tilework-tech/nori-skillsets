#!/usr/bin/env bash
# tui-stop: Kill tmux session and cleanup
#
# Usage: tui-stop <session>

set -euo pipefail

SOCKET="nori-agent-sock"

if [[ $# -lt 1 ]]; then
    echo "Usage: tui-stop <session>" >&2
    exit 1
fi

SESSION=$1

if tmux -f /dev/null -L "$SOCKET" kill-session -t "$SESSION" 2>/dev/null; then
    echo "Stopped session '$SESSION'"
else
    echo "Session '$SESSION' not found (already stopped?)"
fi

# Clean up failure log if exists
rm -f "${SESSION}_failure.log"
